{
  "name": "pwa-notes",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vue-tsc --noEmit && vite build --mode production",
    "dev": "vite --mode development",
    "prod": "vite --mode production",
    "serve": "vite preview",
    "test": "vitest --coverage",
    "lint": "npm run lint:scripts && npm run lint:styles",
    "lint:fix": "npm run lint:scripts:fix && npm run lint:styles:fix",
    "lint:scripts": "eslint src/**/*.{js,ts,vue}",
    "lint:scripts:fix": "eslint src/**/*.{js,ts,vue}",
    "lint:styles": "stylelint ./src/**/*.{scss,vue}",
    "lint:styles:fix": "stylelint ./src/**/*.{scss,vue} --fix",
    "prettier": "prettier src/**/*.{js,ts,tsx,vue,json} --write",
    "analyze": "vite build --mode analyze"
  },
  "dependencies": {
    "@primevue/themes": "^4.5.4",
    "dexie": "^4.4.3",
    "pinia": "^3.0.4",
    "primevue": "^4.5.5",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@config-federation/vue": "^1.0.3",
    "@formkit/auto-animate": "^0.9.0",
    "@heroicons/vue": "^2.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "jiti": "^2.7.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "stylelint": "^17.12.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-property-sort-order-smacss": "^11.2.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-bundle-analyzer": "^1.3.8",
    "vite-plugin-pwa": "^1.3.0",
    "vue-tsc": "^3.3.3",
    "vuedraggable": "^4.1.0"
  }
}
